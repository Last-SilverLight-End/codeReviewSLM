# PostgreSQL
POSTGRES_USER=codereview
POSTGRES_PASSWORD=change-me
POSTGRES_DB=codereview_db
DATABASE_URL=postgresql://codereview:change-me@localhost:5433/codereview_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Elasticsearch / Kibana
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_LOG_ENABLED=true
ELASTICSEARCH_LOG_INDEX_PREFIX=codereview
ELASTICSEARCH_LOG_TIMEOUT=2.0
KIBANA_URL=http://localhost:5601

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=qwen3:8b
OLLAMA_VISION_MODEL=llava:7b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_CHAT_ENDPOINT=/api/chat
OLLAMA_EMBED_ENDPOINT=/api/embed

# LLM defaults
LLM_CHAT_TEMPERATURE=0.3
LLM_REVIEW_TEMPERATURE=0.2
LLM_VISION_TEMPERATURE=0.2

# Embedding / retrieval
EMBEDDING_DIMENSION=768
STRIP_THINK_TAGS=true
HYBRID_RRF_RANK_CONSTANT=60
HYBRID_VECTOR_WEIGHT=1.0
HYBRID_ELASTICSEARCH_WEIGHT=1.25

# Project parsing
IGNORE_DIRS=.git,__pycache__,node_modules,dist,build,.next,venv,.venv
MAX_FILE_SIZE_BYTES=1048576
MAX_FILES_PER_PROJECT=200

# JWT
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Optional admin bootstrap script
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-before-use

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Timeouts
OLLAMA_CHAT_TIMEOUT=300.0
OLLAMA_EMBED_TIMEOUT=120.0
OLLAMA_STREAM_CONNECT_TIMEOUT=10.0
OLLAMA_STREAM_WRITE_TIMEOUT=10.0
OLLAMA_STREAM_POOL_TIMEOUT=10.0

# Chat / listing
CHAT_HISTORY_WINDOW=20
CONVERSATION_TITLE_MAX_LENGTH=60
LIST_CONVERSATIONS_LIMIT=100
LIST_REVIEWS_LIMIT=100
WEB_RESULT_SNIPPET_MAX=300

# Web search
WEB_SEARCH_MAX_WORKERS=5
